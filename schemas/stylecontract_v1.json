{
  "ai_authoring_envelope": {
    "targetRepo": "Horror.Place",
    "targetPath": [
      "schemas/stylecontractv1.json"
    ],
    "schemaref": [
      "schema://HorrorPlace-Constellation-Contracts/schemas/ai-authoring-envelope-v1.json"
    ],
    "tier": "public",
    "intent": "Migrate style contract schema to draft-2020-12, cross-link canonical invariants/metrics, and encode implicationRules for evidence-allowed/depiction-forbidden constraints.",
    "aiauthoringcontract": "schema-migration-v1",
    "agentProfileId": "horrorplace-schema-author",
    "changeset": [
      {
        "path": "schemas/stylecontractv1.json",
        "kind": "schema",
        "schemaref": "https://json-schema.org/draft/2020-12/schema",
        "content": {
          "$schema": "https://json-schema.org/draft/2020-12/schema",
          "$id": "https://horrorplace.org/schemas/stylecontractv1.json",
          "title": "Horror$Place Style Contract Schema v1",
          "description": "Canonical style contract binding aesthetic/tonal styles to invariant constraints, entertainment metrics, and implication rules, compliant with the Rivers of Blood Charter.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "styleId",
            "name",
            "description",
            "safetyTier",
            "platforms",
            "evidenceTypes",
            "forbiddenDepictions",
            "invariantConstraints",
            "metricTargetBands",
            "implicationRules",
            "version"
          ],
          "properties": {
            "styleId": {
              "type": "string",
              "pattern": "^style\\.[a-z0-9_\\-]+\\.v[0-9]+$",
              "description": "Canonical identifier for the style contract."
            },
            "version": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
              "description": "Semantic version of this style contract."
            },
            "name": {
              "type": "string",
              "description": "Human-readable name for the style."
            },
            "description": {
              "type": "string",
              "description": "Implication-only description of the style's aesthetic and thematic elements. Must not contain explicit gore or direct trauma narration."
            },
            "safetyTier": {
              "type": "string",
              "enum": [
                "public",
                "mature",
                "research"
              ],
              "description": "Safety tier as defined by the Rivers of Blood Charter."
            },
            "platforms": {
              "type": "array",
              "description": "List of supported platforms (e.g., web, vr, bci).",
              "items": {
                "type": "string"
              }
            },
            "evidenceTypes": {
              "type": "array",
              "description": "Acceptable evidence types emphasized by this style (e.g., spectral_static, archival_ledger).",
              "items": {
                "type": "string"
              }
            },
            "forbiddenDepictions": {
              "type": "array",
              "description": "Explicitly forbidden visual or narrative elements that would violate the Rivers of Blood Charter.",
              "items": {
                "type": "string",
                "enum": [
                  "human_anatomy_direct",
                  "graphic_violence",
                  "explicit_suffering",
                  "decontextualized_horror",
                  "violates_procedural_implication_doctrine"
                ]
              }
            },
            "invariantConstraints": {
              "type": "object",
              "description": "Minimum/maximum invariant ranges this style assumes. Keys mirror the canonical invariant spine.",
              "additionalProperties": false,
              "properties": {
                "CIC": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "MDI": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "AOS": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "RRM": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "FCF": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "SPR": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "RWF": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "HVF": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "LSG": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "SHCI": {
                  "$ref": "#/$defs/invariantConstraint01"
                },
                "DET": {
                  "$ref": "#/$defs/invariantConstraintDET"
                }
              }
            },
            "metricTargetBands": {
              "type": "object",
              "description": "Target bands for entertainment metrics under this style.",
              "additionalProperties": false,
              "properties": {
                "UEC": {
                  "$ref": "#/$defs/metricBand"
                },
                "EMD": {
                  "$ref": "#/$defs/metricBand"
                },
                "STCI": {
                  "$ref": "#/$defs/metricBand"
                },
                "CDL": {
                  "$ref": "#/$defs/metricBand"
                },
                "ARR": {
                  "$ref": "#/$defs/metricBand"
                }
              }
            },
            "metricLevers": {
              "type": "object",
              "description": "Relative influence of this style on metrics, used as additive offsets or weights.",
              "additionalProperties": false,
              "properties": {
                "UEC": {
                  "type": "number",
                  "minimum": -1.0,
                  "maximum": 1.0
                },
                "EMD": {
                  "type": "number",
                  "minimum": -1.0,
                  "maximum": 1.0
                },
                "STCI": {
                  "type": "number",
                  "minimum": -1.0,
                  "maximum": 1.0
                },
                "CDL": {
                  "type": "number",
                  "minimum": -1.0,
                  "maximum": 1.0
                },
                "ARR": {
                  "type": "number",
                  "minimum": -1.0,
                  "maximum": 1.0
                }
              }
            },
            "implicationRules": {
              "type": "array",
              "description": "Implication-only rules describing what this style permits, forbids, or recommends in different content domains.",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/implicationRule"
              }
            },
            "deadledgerref": {
              "$ref": "#/$defs/deadledgerRef",
              "description": "Optional cryptographic attestation for higher-risk styles, typically required for mature/research tiers."
            }
          },
          "$defs": {
            "invariantConstraint01": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0
                },
                "max": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0
                },
                "required": {
                  "type": "boolean",
                  "default": false
                },
                "weight": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "default": 1.0
                }
              }
            },
            "invariantConstraintDET": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 10.0
                },
                "max": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 10.0
                },
                "required": {
                  "type": "boolean",
                  "default": false
                },
                "weight": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "default": 1.0
                }
              }
            },
            "metricBand": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0
                },
                "max": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0
                },
                "deltaCap": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "default": 0.15
                },
                "priority": {
                  "type": "string",
                  "enum": [
                    "high",
                    "medium",
                    "low"
                  ],
                  "default": "medium"
                }
              }
            },
            "implicationRule": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "ruleType",
                "category",
                "intent"
              ],
              "properties": {
                "ruleType": {
                  "type": "string",
                  "enum": [
                    "allowed",
                    "forbidden",
                    "recommended"
                  ],
                  "description": "Whether the content category is explicitly permitted, banned, or encouraged under this style."
                },
                "category": {
                  "type": "string",
                  "enum": [
                    "visual",
                    "audio",
                    "narrative",
                    "mechanics",
                    "environmental"
                  ],
                  "description": "Domain of the implication rule."
                },
                "intent": {
                  "type": "string",
                  "minLength": 10,
                  "maxLength": 512,
                  "description": "Implication-only description of intended effect. Must not contain explicit gore or direct trauma content."
                },
                "metricImpact": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "primaryMetric": {
                      "type": "string",
                      "enum": [
                        "UEC",
                        "EMD",
                        "STCI",
                        "CDL",
                        "ARR"
                      ]
                    },
                    "expectedDelta": {
                      "type": "number",
                      "minimum": -1.0,
                      "maximum": 1.0
                    }
                  }
                }
              }
            },
            "deadledgerRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "proofEnvelopeId",
                "verifierRef",
                "circuitType"
              ],
              "properties": {
                "proofEnvelopeId": {
                  "type": "string"
                },
                "verifierRef": {
                  "type": "string"
                },
                "circuitType": {
                  "type": "string"
                },
                "requiredProofs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    ]
  }
}
