{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://horror.place/schemas/seedcontractv1.json",
  "title": "Horror.Place Seed Contract v1",
  "description": "A Seed is the smallest, history-bound, engine-consumable unit linking a tile to a staged horror sequence, invariant profile, and target metric shifts.",
  "type": "object",
  "required": [
    "schema",
    "seed_id",
    "version",
    "region_id",
    "tile_id",
    "stage",
    "created_at",
    "updated_at",
    "safety_tier",
    "intensity_band",
    "invariants",
    "metric_targets",
    "bundle_ref",
    "persona_hooks",
    "narrative_affordances",
    "engine_profile",
    "explicit_violence_forbidden"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "format": "uri",
      "const": "https://horror.place/schemas/seedcontractv1.json",
      "description": "Fixed URI for validator resolution."
    },
    "seed_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$",
      "minLength": 8,
      "maxLength": 64,
      "description": "Unique, stable identifier for this Seed."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version string for this Seed record."
    },
    "region_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$",
      "description": "ID of the parent region, consistent with Horror.Place region registries and Black-Archivum bundles."
    },
    "tile_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$",
      "description": "Engine-scale identifier (grid cell / volume / ALN node) where this Seed lives."
    },
    "stage": {
      "type": "string",
      "enum": [
        "stage_1_probe",
        "stage_2_evidence",
        "stage_3_confrontation",
        "stage_4_aftermath",
        "stage_5_residual"
      ],
      "description": "Enum mapping to the five-stage horror sequence model."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of Seed creation."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last Seed modification."
    },
    "safety_tier": {
      "type": "string",
      "enum": ["standard", "mature", "research"],
      "description": "Aligned with Horror.Place safety tier patterns."
    },
    "intensity_band": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "Intensity rating 0–10; bands ≥8 require a non-null deadledger_ref."
    },
    "deadledger_ref": {
      "type": ["string", "null"],
      "pattern": "^dl_[a-z0-9]{16,32}$",
      "description": "Optional but required (by policy) when intensity_band >= 8; points to attested Dead-Ledger entry."
    },

    "invariants": {
      "type": "object",
      "required": [
        "CIC",
        "MDI",
        "AOS",
        "RRM",
        "FCF",
        "SPR",
        "RWF",
        "DET",
        "LSG",
        "SHCI",
        "HVF",
        "time_phase"
      ],
      "additionalProperties": false,
      "properties": {
        "CIC": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Catastrophic Imprint Coefficient."
        },
        "MDI": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Mythic Density Index."
        },
        "AOS": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Archival Opacity Score."
        },
        "RRM": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Ritual Residue Map."
        },
        "FCF": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Folkloric Convergence Factor."
        },
        "SPR": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Spectral Plausibility Rating."
        },
        "RWF": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Reliability Weighting Factor."
        },
        "DET": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Dread Exposure Threshold."
        },
        "LSG": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Liminal Stress Gradient."
        },
        "SHCI": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Spectral-History Coupling Index."
        },
        "HVF": {
          "type": "object",
          "required": ["mag"],
          "additionalProperties": false,
          "properties": {
            "mag": {
              "type": "number",
              "minimum": 0,
              "maximum": 10,
              "description": "Haunt Vector Field magnitude."
            },
            "dir": {
              "type": ["string", "null"],
              "enum": [
                "N",
                "NE",
                "E",
                "SE",
                "S",
                "SW",
                "W",
                "NW",
                "UP",
                "DOWN",
                "RADIAL",
                null
              ],
              "description": "Optional compass/graph direction for HVF flow."
            }
          }
        },
        "time_phase": {
          "type": "object",
          "required": ["phase"],
          "additionalProperties": false,
          "properties": {
            "phase": {
              "type": "string",
              "enum": [
                "day",
                "dusk",
                "night",
                "dawn",
                "storm",
                "anniversary_window",
                "always"
              ]
            },
            "window_minutes": {
              "type": ["integer", "null"],
              "minimum": 1,
              "maximum": 1440,
              "description": "Optional diegetic time window in minutes."
            }
          }
        }
      }
    },

    "metric_targets": {
      "type": "object",
      "required": [
        "UEC_delta",
        "EMD_delta",
        "STCI_delta",
        "CDL_delta",
        "ARR_min",
        "ARR_max"
      ],
      "additionalProperties": false,
      "properties": {
        "UEC_delta": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Target shift in Uncertainty Engagement Coefficient."
        },
        "EMD_delta": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Target shift in Evidential Mystery Density."
        },
        "STCI_delta": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Target shift in Safe-Threat Contrast Index."
        },
        "CDL_delta": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Target shift in Cognitive Dissonance Load."
        },
        "ARR_min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Minimum acceptable Ambiguous Resolution Ratio post-activation."
        },
        "ARR_max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Maximum acceptable Ambiguous Resolution Ratio post-activation."
        },
        "max_session_contrib": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Optional cap on cumulative metric contribution per session to prevent over-saturation."
        }
      }
    },

    "bundle_ref": {
      "type": "object",
      "required": ["id", "hash"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ba_[a-z0-9]{16,32}$",
          "description": "Black-Archivum bundle ID this Seed inherits from."
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hash of the referenced bundle at time of Seed creation."
        }
      }
    },

    "archiverecord_ids": {
      "type": ["array", "null"],
      "description": "Optional array of archive record IDs this Seed conceptually echoes.",
      "items": {
        "type": "string",
        "pattern": "^ar_[a-z0-9._-]{8,64}$"
      }
    },

    "biome_profile_id": {
      "type": ["string", "null"],
      "pattern": "^bp_[a-z0-9._-]+$",
      "description": "Link into biome/atmosphere/audio style system."
    },

    "persona_hooks": {
      "type": "object",
      "required": ["primary_modes"],
      "additionalProperties": false,
      "properties": {
        "primary_modes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "description": "Primary persona modes aligned with Spectral-Foundry taxonomy.",
          "items": {
            "type": "string",
            "enum": [
              "archivist",
              "witness",
              "echo",
              "threshold",
              "process",
              "void"
            ]
          }
        },
        "shci_band": {
          "type": ["string", "null"],
          "enum": [
            "reenactment",
            "echo",
            "glitch",
            null
          ],
          "description": "Optional override for SHCI-driven behavioral constraints."
        },
        "allowed_entities": {
          "type": ["array", "null"],
          "description": "Optional IDs referencing persona/species/loop schemas.",
          "items": {
            "type": "string",
            "pattern": "^ent_[a-z0-9._-]{8,64}$"
          }
        }
      }
    },

    "narrative_affordances": {
      "type": "object",
      "required": [
        "clue_types",
        "player_actions",
        "resolution_modes"
      ],
      "additionalProperties": false,
      "properties": {
        "clue_types": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "description": "Evidence categories matching style DSL.",
          "items": {
            "type": "string",
            "enum": [
              "contradictory_record",
              "missing_person_reference",
              "spectral_testimony_fragment",
              "environmental_anomaly",
              "ritual_artifact",
              "archival_gap",
              "rumor_chain"
            ]
          }
        },
        "player_actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "description": "Verbs Director/Story can bind to mechanics.",
          "items": {
            "type": "string",
            "enum": [
              "observe",
              "document",
              "evade",
              "follow_sound",
              "wait",
              "refuse",
              "interact",
              "flee"
            ]
          }
        },
        "resolution_modes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "description": "Controls ARR and CDL interplay post-activation.",
          "items": {
            "type": "string",
            "enum": [
              "none",
              "partial",
              "branch",
              "late_revelation"
            ]
          }
        },
        "loop_id": {
          "type": ["string", "null"],
          "pattern": "^loop_[a-z0-9._-]+$",
          "description": "Optional ID if this Seed is a node in a Spectral Loop contract."
        }
      }
    },

    "stage_graph": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Optional adjacency hints for multi-Seed arc planning.",
      "properties": {
        "previous": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9._-]+$"
          }
        },
        "next": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9._-]+$"
          }
        }
      }
    },

    "engine_profile": {
      "type": "object",
      "required": [
        "trigger_cooldown_sec",
        "max_triggers_per_session"
      ],
      "additionalProperties": false,
      "properties": {
        "trigger_cooldown_sec": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600,
          "description": "Minimum seconds between activations of this Seed."
        },
        "max_triggers_per_session": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum times this Seed can fire per player session."
        },
        "required_player_state": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "description": "Optional constraints on player metrics for Seed eligibility.",
          "properties": {
            "DET_min": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            },
            "DET_max": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            },
            "CDL_min": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            },
            "CDL_max": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            },
            "UEC_min": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            },
            "UEC_max": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            }
          }
        },
        "ls_thresholds": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "description": "Liminal thresholds where HVF/LSG must exceed values for manifestation.",
          "properties": {
            "HVF_min": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            },
            "LSG_min": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 10
            }
          }
        }
      }
    },

    "explicit_violence_forbidden": {
      "type": "boolean",
      "const": true,
      "description": "Must be true at Tier-1; forbids explicit violent content in Seed manifestations."
    },

    "charter_profile_id": {
      "type": ["string", "null"],
      "pattern": "^cp_[a-z0-9._-]+$",
      "description": "Optional link to validated Charter profile/ruleset."
    },

    "validator_signature": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Git commit hash or signer ID for validation attestation."
    }
  }
}
