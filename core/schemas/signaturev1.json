{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://Horror.Place/core/schemas/signaturev1.json",
  "title": "Horror.Place First-Pass Signature",
  "description": "Canonical first-pass handoff signature for deterministic, policy-bound generation workflows across the Horror.Place VM-constellation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signature_id",
    "issued_at",
    "expires_at",
    "github_actor",
    "github_repo",
    "github_ref",
    "session_id",
    "target_repo",
    "target_path",
    "workflow_id",
    "operation",
    "schema_ref",
    "contract_type",
    "contract_id",
    "policy_profile",
    "entitlement_tier",
    "invariant_envelope",
    "metric_envelope",
    "shci_lock_mode",
    "capability_token_id",
    "entitlement_proofs",
    "generator_version",
    "random_seed",
    "max_runtime_ms",
    "max_size_bytes",
    "constraints_hash",
    "request_origin"
  ],
  "properties": {
    "signature_id": {
      "type": "string",
      "description": "Stable UUID for this signature instance.",
      "format": "uuid"
    },
    "issued_at": {
      "type": "string",
      "description": "Signature issuance time (ISO 8601).",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "description": "Signature expiry time (ISO 8601); CI must enforce expires_at > issued_at.",
      "format": "date-time"
    },
    "github_actor": {
      "type": "string",
      "description": "GitHub username of the caller.",
      "minLength": 1
    },
    "github_repo": {
      "type": "string",
      "description": "Full GitHub repo slug (owner/name).",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "github_ref": {
      "type": "string",
      "description": "Git reference (branch or tag) that requested generation.",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "description": "UUID for the cryptographic session; must match Dead-Ledger / ALN session records.",
      "format": "uuid"
    },

    "target_repo": {
      "type": "string",
      "description": "Target repository in the VM-constellation.",
      "enum": [
        "Horror.Place",
        "HorrorPlace-Atrocity-Seeds",
        "HorrorPlace-Black-Archivum",
        "HorrorPlace-Dead-Ledger-Network",
        "HorrorPlace-Neural-Resonance-Lab",
        "HorrorPlace-Process-Gods-Research",
        "HorrorPlace-Liminal-Continuum",
        "HorrorPlace-Obscura-Nexus",
        "HorrorPlace-Redacted-Chronicles",
        "HorrorPlace-Spectral-Foundry"
      ]
    },
    "target_path": {
      "type": "string",
      "description": "Repository-relative path for the single file to be generated or updated.",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "description": "CI workflow name or ID.",
      "minLength": 1
    },
    "operation": {
      "type": "string",
      "description": "Requested operation on the target file.",
      "enum": [
        "create",
        "update",
        "validate_only"
      ]
    },
    "schema_ref": {
      "type": "string",
      "description": "Canonical schema URI the generated file must conform to.",
      "minLength": 1
    },

    "contract_type": {
      "type": "string",
      "description": "High-level contract type being written or modified.",
      "enum": [
        "event",
        "persona",
        "style",
        "registry_entry",
        "invariant_bundle",
        "routing_profile",
        "policy_profile",
        "deadledger_integration_doc",
        "other"
      ]
    },
    "contract_id": {
      "type": "string",
      "description": "Stable ID of the contract or registry entry this signature applies to.",
      "minLength": 1
    },
    "style_id": {
      "type": "string",
      "description": "Style contract ID to be enforced (when applicable).",
      "minLength": 1
    },
    "policy_profile": {
      "type": "string",
      "description": "Policy profile identifier (e.g., STANDARD_V1, MATURE_V1, RESEARCH_V1).",
      "minLength": 1
    },
    "entitlement_tier": {
      "type": "string",
      "description": "Entitlement tier for this operation.",
      "enum": [
        "tier1_core",
        "tier2_vault",
        "tier3_lab"
      ]
    },

    "invariant_envelope": {
      "type": "object",
      "description": "Required ranges for history invariants.",
      "additionalProperties": false,
      "required": [
        "CIC",
        "MDI",
        "AOS",
        "RRM",
        "FCF",
        "SPR",
        "RWF",
        "DET",
        "HVF",
        "LSG",
        "SHCI"
      ],
      "properties": {
        "CIC": { "$ref": "#/$defs/range01" },
        "MDI": { "$ref": "#/$defs/range01" },
        "AOS": { "$ref": "#/$defs/range01" },
        "RRM": { "$ref": "#/$defs/range01" },
        "FCF": { "$ref": "#/$defs/range01" },
        "SPR": { "$ref": "#/$defs/range01" },
        "RWF": { "$ref": "#/$defs/range01" },
        "DET": { "$ref": "#/$defs/range01" },
        "HVF": { "$ref": "#/$defs/range01" },
        "LSG": { "$ref": "#/$defs/range01" },
        "SHCI": { "$ref": "#/$defs/range01" }
      }
    },
    "metric_envelope": {
      "type": "object",
      "description": "Target bands for entertainment metrics.",
      "additionalProperties": false,
      "required": [
        "UEC",
        "EMD",
        "STCI",
        "CDL",
        "ARR"
      ],
      "properties": {
        "UEC": { "$ref": "#/$defs/range01" },
        "EMD": { "$ref": "#/$defs/range01" },
        "STCI": { "$ref": "#/$defs/range01" },
        "CDL": { "$ref": "#/$defs/range01" },
        "ARR": { "$ref": "#/$defs/range01" }
      }
    },
    "shci_lock_mode": {
      "type": "string",
      "description": "How strictly SHCI and history invariants must constrain behavior.",
      "enum": [
        "strict",
        "loose"
      ]
    },

    "capability_token_id": {
      "type": "string",
      "description": "Identifier of the session-bound capability token used to authorize this signature.",
      "minLength": 1
    },
    "entitlement_proofs": {
      "type": "array",
      "description": "Opaque references to ZKP / ALN proofs, not raw proofs.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },

    "generator_version": {
      "type": "string",
      "description": "Semantic version of the generator or persona profile.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "random_seed": {
      "type": "string",
      "description": "256-bit hex string; generator must treat this as the only randomness source.",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "max_runtime_ms": {
      "type": "integer",
      "description": "Upper bound on generator runtime in milliseconds.",
      "minimum": 1
    },
    "max_size_bytes": {
      "type": "integer",
      "description": "Upper bound on generated file size in bytes.",
      "minimum": 1
    },
    "constraints_hash": {
      "type": "string",
      "description": "SHA-256 over the concatenation of schema_ref, contract_id, invariant_envelope, and metric_envelope.",
      "pattern": "^[0-9a-fA-F]{64}$"
    },

    "request_origin": {
      "type": "string",
      "description": "Origin of the request.",
      "enum": [
        "ci_workflow",
        "manual_dispatch",
        "api_call"
      ]
    },
    "parent_signature_id": {
      "type": "string",
      "description": "Optional link to a previous signature for lineage.",
      "format": "uuid"
    },
    "dead_ledger_tx": {
      "type": "string",
      "description": "Optional hash or ID of the Dead-Ledger entry registering this signature.",
      "minLength": 1
    }
  },
  "$defs": {
    "range01": {
      "type": "object",
      "description": "Inclusive [min,max] range within [0.0,1.0].",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "contract_type": { "const": "style" }
        }
      },
      "then": {
        "required": [ "style_id" ]
      }
    }
  ]
}
