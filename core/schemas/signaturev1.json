{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema.Horror.Place/core/schemas/signaturev1.json",
  "title": "Horror.Place First-Pass Signature v1",
  "description": "CI-governed signature document embedding contractCard for invariant/metric enforcement. Used by schema_spine_scanner for pre-commit validation across the Horror.Place VM-constellation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signatureid",
    "issuedat",
    "expiresat",
    "githubactor",
    "githubrepo",
    "githubref",
    "sessionid",
    "workflowintent",
    "target",
    "schemaref",
    "contracttype",
    "contractid",
    "policyprofile",
    "entitlementtier",
    "invariantenvelope",
    "metricenvelope",
    "shcilockmode",
    "capabilitytokenid",
    "entitlementproofs",
    "generatorversion",
    "randomseed",
    "maxruntimems",
    "maxsizebytes",
    "constraintshash",
    "requestorigin",
    "contractCard"
  ],
  "properties": {
    "signatureid": {
      "type": "string",
      "pattern": "^sig-[0-9]{8}-[0-9]{4}$",
      "description": "Unique identifier for this signature instance."
    },
    "issuedat": {
      "type": "string",
      "description": "Signature issuance time (ISO 8601).",
      "format": "date-time"
    },
    "expiresat": {
      "type": "string",
      "description": "Signature expiry time (ISO 8601); CI must enforce expiresat > issuedat.",
      "format": "date-time"
    },
    "githubactor": {
      "type": "string",
      "description": "GitHub username of the caller.",
      "minLength": 1
    },
    "githubrepo": {
      "type": "string",
      "description": "Full GitHub repo slug (owner/name).",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "githubref": {
      "type": "string",
      "description": "Git reference (branch or tag) that requested generation.",
      "minLength": 1
    },
    "sessionid": {
      "type": "string",
      "description": "UUID for the cryptographic session; must match Dead-Ledger / ALN session records.",
      "format": "uuid"
    },
    "workflowintent": {
      "type": "string",
      "enum": [
        "pcg-generator",
        "asset-placement",
        "event-scripting",
        "npc-behavior",
        "audio-mixing",
        "narrative-beat"
      ],
      "description": "Intended use case for this signature."
    },
    "target": {
      "type": "object",
      "required": ["repo", "path"],
      "properties": {
        "repo": {
          "type": "string",
          "description": "Target repository in the VM-constellation.",
          "enum": [
            "Horror.Place",
            "HorrorPlace-Atrocity-Seeds",
            "HorrorPlace-Black-Archivum",
            "HorrorPlace-Dead-Ledger-Network",
            "HorrorPlace-Neural-Resonance-Lab",
            "HorrorPlace-Process-Gods-Research",
            "HorrorPlace-Liminal-Continuum",
            "HorrorPlace-Obscura-Nexus",
            "HorrorPlace-Redacted-Chronicles",
            "HorrorPlace-Spectral-Foundry"
          ]
        },
        "path": {
          "type": "string",
          "description": "Repository-relative path for the single file to be generated or updated.",
          "pattern": "^(seeds/|events/|assets/|blueprints/).+"
        }
      }
    },
    "schemaref": {
      "type": "string",
      "pattern": "^horror\\.place\\.schema\\.v1:[a-z0-9_.-]+$",
      "description": "Primary schema for generated artifact type."
    },
    "contracttype": {
      "type": "string",
      "description": "High-level contract type being written or modified.",
      "enum": [
        "event",
        "persona",
        "style",
        "registry_entry",
        "invariant_bundle",
        "routing_profile",
        "policy_profile",
        "deadledger_integration_doc",
        "other"
      ]
    },
    "contractid": {
      "type": "string",
      "description": "Stable ID of the contract or registry entry this signature applies to.",
      "minLength": 1
    },
    "styleid": {
      "type": "string",
      "description": "Style contract ID to be enforced (when applicable).",
      "minLength": 1
    },
    "policyprofile": {
      "type": "string",
      "description": "Policy profile identifier (e.g., STANDARD_V1, MATURE_V1, RESEARCH_V1).",
      "minLength": 1
    },
    "entitlementtier": {
      "type": "string",
      "description": "Entitlement tier for this operation.",
      "enum": [
        "tier1_core",
        "tier2_vault",
        "tier3_lab"
      ]
    },
    "invariantenvelope": {
      "type": "object",
      "description": "Allowed ranges for history invariants; contractCard values must lie within.",
      "additionalProperties": false,
      "required": [
        "CIC",
        "MDI",
        "AOS",
        "RRM",
        "FCF",
        "SPR",
        "RWF",
        "DET",
        "HVF",
        "LSG",
        "SHCI"
      ],
      "properties": {
        "CIC": { "$ref": "#/$defs/range01" },
        "MDI": { "$ref": "#/$defs/range01" },
        "AOS": { "$ref": "#/$defs/range01" },
        "RRM": { "$ref": "#/$defs/range01" },
        "FCF": { "$ref": "#/$defs/range01" },
        "SPR": { "$ref": "#/$defs/range01" },
        "RWF": { "$ref": "#/$defs/range01" },
        "DET": { "$ref": "#/$defs/range010" },
        "HVF": { "$ref": "#/$defs/range01" },
        "LSG": { "$ref": "#/$defs/range01" },
        "SHCI": { "$ref": "#/$defs/range01" }
      }
    },
    "metricenvelope": {
      "type": "object",
      "description": "Allowed bands for outcome metrics; must match contractCard exactly.",
      "additionalProperties": false,
      "required": [
        "UEC",
        "EMD",
        "STCI",
        "CDL",
        "ARR"
      ],
      "properties": {
        "UEC": { "$ref": "#/$defs/band01" },
        "EMD": { "$ref": "#/$defs/band01" },
        "STCI": { "$ref": "#/$defs/band01" },
        "CDL": { "$ref": "#/$defs/band01" },
        "ARR": { "$ref": "#/$defs/band01" }
      }
    },
    "shcilockmode": {
      "type": "string",
      "description": "How strictly SHCI and history invariants must constrain behavior.",
      "enum": [
        "strict",
        "loose"
      ]
    },
    "capabilitytokenid": {
      "type": "string",
      "description": "ALN capability token governing this signature's permissions.",
      "minLength": 1
    },
    "alncontractids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^aln://"
      },
      "description": "Authorization and Ledger Network contract references."
    },
    "entitlementproofs": {
      "type": "array",
      "description": "Opaque references to ZKP / ALN proofs, not raw proofs.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generatorversion": {
      "type": "string",
      "description": "Semantic version of the generator or persona profile.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "randomseed": {
      "type": "string",
      "description": "Deterministic seed for reproducible generation (no hidden defaults); 256-bit hex string.",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "maxruntimems": {
      "type": "integer",
      "description": "Upper bound on generator runtime in milliseconds.",
      "minimum": 1
    },
    "maxsizebytes": {
      "type": "integer",
      "description": "Upper bound on generated file size in bytes.",
      "minimum": 1
    },
    "constraintshash": {
      "type": "string",
      "description": "SHA-256 over the concatenation of schemaref, contractid, invariantenvelope, and metricenvelope.",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "requestorigin": {
      "type": "string",
      "description": "Origin of the request.",
      "enum": [
        "ci_workflow",
        "manual_dispatch",
        "api_call"
      ]
    },
    "parentsignatureid": {
      "type": "string",
      "description": "Optional link to a previous signature for lineage.",
      "format": "uuid"
    },
    "deadledgertx": {
      "type": "string",
      "description": "Optional hash or ID of the Dead-Ledger entry registering this signature.",
      "minLength": 1
    },
    "contractCard": {
      "$ref": "coreschemascontractcardv1.json",
      "description": "Embedded contract card; subset rule: values must satisfy envelope constraints."
    },
    "generatedartifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "schemaref", "styleid"],
        "properties": {
          "path": { "type": "string" },
          "schemaref": { "type": "string" },
          "styleid": { "type": "string" },
          "deadledgerref": { "type": "string" }
        }
      },
      "description": "List of artifacts generated under this signature (for audit)."
    }
  },
  "$defs": {
    "range01": {
      "type": "object",
      "description": "Inclusive [min,max] range within [0.0,1.0].",
      "additionalProperties": false,
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "range010": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        },
        "max": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0
        }
      }
    },
    "band01": {
      "type": "array",
      "items": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "minItems": 2,
      "maxItems": 2
    },
    "mustBeInEnvelope": {
      "type": "number"
    },
    "mustBeInEnvelopeDET": {
      "type": "number"
    },
    "mustMatchBand": {
      "type": "array",
      "items": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      },
      "minItems": 2,
      "maxItems": 2
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "contracttype": { "const": "style" }
        }
      },
      "then": {
        "required": ["styleid"]
      }
    },
    {
      "description": "Subset Rule: contractCard invariants must lie within envelope",
      "if": { "required": ["contractCard", "invariantenvelope"] },
      "then": {
        "properties": {
          "contractCard": {
            "properties": {
              "invariants": {
                "properties": {
                  "CIC": { "$ref": "#/$defs/mustBeInEnvelope" },
                  "AOS": { "$ref": "#/$defs/mustBeInEnvelope" },
                  "RRM": { "$ref": "#/$defs/mustBeInEnvelope" },
                  "LSG": { "$ref": "#/$defs/mustBeInEnvelope" },
                  "DET": { "$ref": "#/$defs/mustBeInEnvelopeDET" },
                  "SHCI": { "$ref": "#/$defs/mustBeInEnvelope" }
                }
              }
            }
          }
        }
      }
    },
    {
      "description": "Band Match Rule: contractCard metrics must equal envelope bands",
      "if": { "required": ["contractCard", "metricenvelope"] },
      "then": {
        "properties": {
          "contractCard": {
            "properties": {
              "metrics": {
                "properties": {
                  "UEC": { "$ref": "#/$defs/mustMatchBand" },
                  "EMD": { "$ref": "#/$defs/mustMatchBand" },
                  "STCI": { "$ref": "#/$defs/mustMatchBand" },
                  "CDL": { "$ref": "#/$defs/mustMatchBand" },
                  "ARR": { "$ref": "#/$defs/mustMatchBand" }
                }
              }
            }
          }
        }
      }
    }
  ]
}
