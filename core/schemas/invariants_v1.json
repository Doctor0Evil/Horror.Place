{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema://Horror.Place/core/schemas/invariants_v1",
  "title": "Horror.Place Invariants Schema v1",
  "description": "Defines safety invariants, content boundary constraints, and no-raw-content guarantees enforced across all Horror.Place registries and artifacts.",
  "type": "object",
  "required": ["invariant_id", "version", "rules"],
  "properties": {
    "invariant_id": {
      "type": "string",
      "pattern": "^INV-[0-9]{4}$",
      "description": "Unique invariant identifier."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the invariant set."
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "description", "enforcement", "severity"],
        "properties": {
          "rule_id": {
            "type": "string",
            "pattern": "^R-[A-Z]{2,6}-[0-9]{3}$"
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500
          },
          "enforcement": {
            "type": "string",
            "enum": ["ci_lint", "runtime_gate", "manual_review", "schema_validation"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "automated_test_hook": {
            "type": "string",
            "description": "Path to automated test that validates this rule."
          }
        }
      }
    },
    "content_boundary": {
      "type": "object",
      "description": "Defines what content is prohibited in public repos.",
      "properties": {
        "no_raw_assets": { "type": "boolean", "const": true },
        "no_direct_urls": { "type": "boolean", "const": true },
        "allowed_reference_types": {
          "type": "array",
          "items": { "type": "string", "enum": ["artifact_id", "cid", "schema_ref"] }
        },
        "telemetry_sanitization_required": { "type": "boolean", "const": true }
      },
      "required": ["no_raw_assets", "no_direct_urls", "allowed_reference_types"]
    }
  },
  "additionalProperties": false
}
